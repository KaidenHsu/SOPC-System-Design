/*
 * helloworld.c: simple test application
 *
 * This application configures UART 16550 to baud rate 9600.
 * PS7 UART (Zynq) is not initialized by this application, since
 * bootrom/bsp configures it to baud rate 115200
 *
 * ------------------------------------------------
 * | UART TYPE   BAUD RATE                        |
 * ------------------------------------------------
 *   uartns550   9600
 *   uartlite    Configurable only in HW design
 *   ps7_uart    115200 (configured by bootrom/bsp)
 */

#include <stdio.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "sleep.h"

// 【請確認這個名稱與 xparameters.h 中的一致】
#define VMM_BASE XPAR_HW4IP_0_S00_AXI_BASEADDR

#define REG_CTRL   0x00
#define REG_DIM    0x04
#define REG_I_ADDR 0x08
#define REG_I_DAT_L 0x0C
#define REG_I_DAT_H 0x10
#define REG_O_ADDR 0x14
#define REG_O_DAT  0x18

// ========================================================
// 1. 貼上從 Python 產生出來的 C 陣列 (取代這三行)
// ========================================================
u32 input_data_high[] = {0xc627dc67, 0x55b98b37, 0xde7a9be0, 0x3681f124};
u32 input_data_low[]  = {0xb94a23c7, 0xb00c238a, 0x3628eef3, 0xae00e750};
int golden_data[]     = {114, 15, 95};
// ========================================================

int main() {
    printf("\n--- VMM Hardware Accelerator Verification ---\n\n");

    // 自動計算 M 和 N 的維度
    // n_val 就是 golden_data 的長度
    int n_val = sizeof(golden_data) / sizeof(golden_data[0]);
    // 總資料行數
    int total_input_depth = sizeof(input_data_high) / sizeof(input_data_high[0]);
    // 根據公式推算 M: (total_depth = M/16 + (M/16)*N) => M = (total_depth * 16) / (1 + N)
    int m_val = (total_input_depth * 16) / (1 + n_val);

    printf("Detected Dimensions : M = %d, N = %d\n", m_val, n_val);
    printf("Total SRAM Lines    : %d\n\n", total_input_depth);

    // 2. 設定硬體維度暫存器
    u32 dim_config = (m_val << 8) | n_val;
    Xil_Out32(VMM_BASE + REG_DIM, dim_config);

    // 3. 寫入資料到 Input SRAM
    printf("Writing test data to Input SRAM...\n");
    for(int i = 0; i < total_input_depth; i++) {
        Xil_Out32(VMM_BASE + REG_I_ADDR, i);
        Xil_Out32(VMM_BASE + REG_I_DAT_L, input_data_low[i]);
        Xil_Out32(VMM_BASE + REG_I_DAT_H, input_data_high[i]);
    }

    // 4. 發送 1 Cycle 的 Start 脈衝
    printf("Sending Start Pulse to Hardware...\n");
    Xil_Out32(VMM_BASE + REG_CTRL, 0x01);
    Xil_Out32(VMM_BASE + REG_CTRL, 0x00);

    // 5. 輪詢 (Polling) 等待 Finish 鎖存訊號
    printf("Waiting for hardware to compute...\n");
    u32 status;
    do {
        status = Xil_In32(VMM_BASE + REG_CTRL);
    } while (!(status & 0x02)); // 檢查 bit 1 (Finish)

    // 讀取完畢後，可以選擇把 Control 暫存器清零，為下次運算做準備
    Xil_Out32(VMM_BASE + REG_CTRL, 0x00);
    printf("Hardware Finished!\n\n");

    // 6. 讀取結果並與 Golden Data 比對
    printf("Verifying Results:\n");
    int passed = 1;

    for(int j = 0; j < n_val; j++) {
        Xil_Out32(VMM_BASE + REG_O_ADDR, j);
        u32 result = Xil_In32(VMM_BASE + REG_O_DAT);

        // 符號擴展 (12-bit signed to 32-bit signed int)
        int signed_res = (int)(result & 0xFFF);
        if (signed_res & 0x800) signed_res |= 0xFFFFF000;

        printf("  Result [%2d]: %6d \t| Golden: %6d", j, signed_res, golden_data[j]);

        if (signed_res != golden_data[j]) {
            printf("  <-- [MISMATCH]\n");
            passed = 0;
        } else {
            printf("  <-- [OK]\n");
        }
    }

    // 7. 最終判定
    printf("\n");
    if (passed == 1) {
    	printf("\n");
    	printf("\n");
    	        printf("        ==================================\n");
    	        printf("        ==   ALL TESTS PASSED! MEOW~    ==\n");
    	        printf("        ==================================\n");
    	        printf("                  /\\___/\ \n");
    	        printf("                 ( o   o  ) \n");
    	        printf("                 (  =^=   ) \n");
    	        printf("                 (        ) \n");
    	        printf("                 (         ) \n");
    	        printf("                 (          ))))))");
    } else {
        printf("        [ERROR] Simulation Failed. Check hardware logic or timing.\n\n");
    }

    return 0;
}
